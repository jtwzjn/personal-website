# Personal Website Environment Variables
# Copy this file to .env.local and fill in your values

# GitHub personal access token with public_repo read permission
# Optional: if not provided, GitHub API will be called without authentication (lower rate limit)
GITHUB_TOKEN=

# GitHub username to fetch repositories for
GITHUB_USERNAME=

# Vercel Deploy Hook URL for GitHub webhook integration
# Optional: used to trigger redeploys on repository changes
VERCEL_DEPLOY_HOOK_URL=

# Sentry DSN for error tracking
# Optional: only needed in production
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Decap CMS GitHub OAuth credentials
# Required for /admin login
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
